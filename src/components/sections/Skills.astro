---
interface Skill {
	name: string;
	category?: string;
	level?: string;
}

interface Props {
	skills: Skill[];
}

const { skills } = Astro.props;
---

{
	skills.length > 0 && (
		<section class="skills" id="skills">
			<div class="skills-container">
				<div class="skills-grid-layout">
					<div class="skills-left">
						<div class="skills-sticky">
							<span class="skills-number">
								[02] // EXPERTISE
							</span>
							<div class="contact-heading-wrapper">
								<div class="heading-plus top-left">+</div>
								<div class="heading-plus top-right">+</div>
								<h2 class="skills-heading">Skills</h2>
							</div>
							
							<p class="skills-intro">
								A focused catalog of technologies
								and tools used to construct
								high-performance, aesthetically
								exceptional web platforms.
							</p>
						</div>
					</div>
					<div class="skills-right">
						<div class="skills-list">
							{skills.map((skill: Skill) => (
								<div class="skill-row">
									<div class="skill-meta">
										<span class="skill-name">
											{skill.name}
										</span>
										{skill.category && (
											<span class="skill-category-badge">
												{skill.category}
											</span>
										)}
									</div>
									{skill.level && (
										<div class="skill-level-indicator">
											<span class="skill-level-label">
												{skill.level}
											</span>
										</div>
									)}
								</div>
							))}
						</div>
					</div>
				</div>
			</div>
		</section>
	)
}

<style>
	.skills {
		width: 100vw;
		height: 100vh;
		min-height: 100vh;
		flex-shrink: 0;
		display: flex;
		align-items: center;
		background-color: transparent;
		color: #000000;
		position: relative;
		overflow: hidden;
	}

	.skills-container {
		width: 100%;
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-4xl) var(--spacing-lg);
		position: relative;
		z-index: 2;
	}

	.skills-grid-layout {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--spacing-2xl);
	}

	@media (min-width: 768px) {
		.skills-grid-layout {
			grid-template-columns: 2fr 3fr;
			gap: var(--spacing-4xl);
		}
	}

	.skills-left {
		display: flex;
		flex-direction: column;
	}

	.skills-sticky {
		position: sticky;
		top: var(--spacing-2xl);
	}

	.skills-number {
		font-family: var(--font-mono);
		font-size: var(--font-size-sm);
		color: var(--color-accent);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		display: block;
		margin-bottom: var(--spacing-sm);
	}

	.skills-heading {
		font-family: "Syne", sans-serif;
		font-size: clamp(2.5rem, 5vw, 4.5rem);
		font-weight: 800;
		line-height: 1.1;
		text-transform: uppercase;
		color: #000000;
		margin-bottom: var(--spacing-lg);
		letter-spacing: -0.03em;
	}

	.skills-intro {
		font-size: var(--font-size-base);
		color: #000000;
		line-height: 1.6;
	}

	.skills-list {
		display: flex;
		flex-direction: column;
		border-bottom: 1px solid var(--color-border);
	}

	.skill-row {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: var(--spacing-md) 0;
		border-top: 1px solid var(--color-border);
		transition:
			border-color var(--transition-fast),
			padding var(--transition-fast);
	}

	.skill-row:hover {
		border-color: #000000;
		padding-left: var(--spacing-xs);
		padding-right: var(--spacing-xs);
	}

	.skill-meta {
		display: flex;
		align-items: center;
		gap: var(--spacing-md);
	}

	.skill-name {
		font-family: "Syne", sans-serif;
		font-size: var(--font-size-lg);
		font-weight: 600;
		color: #000000;
		text-transform: uppercase;
		letter-spacing: -0.02em;
	}

	.skill-category-badge {
		font-family: var(--font-mono);
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		padding: 2px 8px;
		border: 1px dashed var(--color-border);
		border-radius: var(--radius);
		color: #000000;
	}

	.skill-row:hover .skill-category-badge {
		border-color: var(--color-accent);
		color: var(--color-accent);
	}

	.skill-level-indicator {
		display: flex;
		align-items: center;
		gap: var(--spacing-sm);
	}

	.skill-level-label {
		font-family: var(--font-mono);
		font-size: var(--font-size-sm);
		text-transform: uppercase;
		color: #000000;
		letter-spacing: 0.05em;
	}

	.skill-row:hover .skill-level-label {
		color: #000000;
	}

	.contact-heading-wrapper {
		position: relative;
		display: inline-block;
		padding: var(--spacing-md);
	}

	.heading-plus {
		position: absolute;
		font-size: 1.5rem;
		color: var(--color-muted);
		opacity: 0.5;
		font-weight: 300;
		line-height: 1;
		pointer-events: none;
	}

	.heading-plus.top-left {
		top: 0;
		left: 0;
	}

	.heading-plus.top-right {
		top: 0;
		right: 0;
	}

	@media (max-width: 768px) {
		.skills-container {
			padding: var(--spacing-2xl) var(--spacing-md);
		}
	}
</style>
