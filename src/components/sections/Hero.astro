---
// Hero.astro
// No props needed — all content is static/hardcoded for now.
// If you want to make the name or tagline dynamic, add Props here.

const title = "Kris Rodriguez";
const titleWords = title.split(" ");
---

<section class="hero">
	<!-- WebGL Wave Background -->
	<canvas id="wave-canvas" class="wave-canvas"></canvas>

	<div class="hero-content">
		<div class="hero-inner">
			<!-- Top Border with Text -->
			<div class="hero-top-border">
				<span class="border-text-left">4+ YEARS EXPERIENCE</span>
				<span class="border-text-right">JUNIOR WEB DEVELOPER</span>
			</div>

			<!-- Large Title -->
			<div class="title-container">
				{
					titleWords.map((word, index) => (
						<div style="overflow: hidden; max-width: 100%;">
							<h1
								class="title-word"
								style={`
									font-family: 'Syne', sans-serif;
									font-weight: 800;
									font-size: ${index === 0 ? "clamp(2.5rem, 10vw, 12rem)" : "clamp(1rem, 5.5vw, 10rem)"};
									transform-origin: left;
									animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) ${index * 0.15}s both;
								`}>
								{index === 0
									? word
											.split("")
											.map((letter, letterIdx) => (
												<span
													class={
														letterIdx === 1
															? "zoom-letter"
															: "normal-letter"
													}>
													{letter}
												</span>
											))
									: word}
							</h1>
						</div>
					))
				}
			</div>

			<!-- Subtitle -->
			<div
				class="subtitle-container"
				style="animation: fadeIn 1s ease-out 0.6s both;">
				<div class="indigo-line"></div>
				<p class="hero-tagline">Design &amp; Development</p>
			</div>
		</div>
	</div>
</section>

<style>
	.hero {
		position: relative;
		height: 100vh;
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		overflow: hidden;
		background-color: transparent;
		color: var(--color-text);
		width: 100%;
		max-width: 100vw;
	}

	.hero-top-border {
		position: relative;
		width: 100%;
		height: 1px;
		background: var(--color-text);
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.border-text-left,
	.border-text-right {
		font-family: var(--font-mono);
		font-size: 0.65rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--color-text);
		background: var(--color-bg);
		padding: 0 var(--spacing-sm);
		position: relative;
		top: -0.5em;
	}

	.zoom-letter {
		color: #ffffff !important;
		background: none !important;
		-webkit-background-clip: unset !important;
		background-clip: unset !important;
		display: inline-block;
		position: relative;
		font-family: 'Playfair Display', 'Georgia', serif !important;
		font-style: italic;
		font-weight: 700;
	}

	.normal-letter {
		color: var(--color-text) !important;
		background: none !important;
		-webkit-background-clip: unset !important;
		background-clip: unset !important;
		display: inline-block;
		position: relative;
	}

	.wave-canvas {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: 0;
		pointer-events: none;
	}

	.hero-content {
		position: relative;
		z-index: 10;
		width: 100%;
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-4xl) var(--spacing-lg);
		display: flex;
		flex-direction: column;
		justify-content: center;
		box-sizing: border-box;
	}

	.hero-inner {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: var(--spacing-xl);
	}

	.title-container {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-sm);
		width: 100%;
		max-width: 100%;
		cursor: default;
		overflow: hidden;
	}

	.title-word {
		font-family: var(--font-sans-syne), sans-serif;
		font-weight: 800;
		line-height: 0.85;
		text-transform: uppercase;
		letter-spacing: -0.05em;
		white-space: nowrap;
		color: transparent;
		background: linear-gradient(
			135deg,
			var(--color-text) 30%,
			var(--color-muted) 100%
		);
		-webkit-background-clip: text;
		background-clip: text;
	}

	.subtitle-container {
		display: flex;
		align-items: center;
		gap: var(--spacing-md);
		margin-top: var(--spacing-lg);
	}

	.indigo-line {
		width: 48px;
		height: 2px;
		background-color: #6366f1;
	}

	.hero-tagline {
		font-size: clamp(1.75rem, 3vw, 2.25rem);
		color: #d1d5db;
		font-family: "Playfair Display", "Georgia", serif;
		font-style: italic;
		font-weight: 400;
		letter-spacing: 0.03em;
		line-height: 1.4;
	}

	@keyframes fadeUp {
		0% {
			opacity: 0;
			transform: translateY(100%) scaleX(1);
		}
		100% {
			opacity: 1;
			transform: translateY(0) scaleX(1.05);
		}
	}

	@keyframes fadeIn {
		0% {
			opacity: 0;
		}
		100% {
			opacity: 1;
		}
	}

	@media (max-width: 768px) {
		.hero {
			padding: var(--spacing-3xl) var(--spacing-lg);
		}

		.hero-content {
			padding: var(--spacing-4xl) var(--spacing-md);
		}

		.title-word {
			max-width: 100vw;
			transform-origin: left center;
		}
	}
</style>

<script>
	import { gsap } from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";

	gsap.registerPlugin(ScrollTrigger);

	// ─── WebGL Wave Background ────────────────────────────────────────────────
	const initWaveBackground = () => {
		const canvas = document.getElementById("wave-canvas") as HTMLCanvasElement;
		if (!canvas) return;

		import("three").then((THREE) => {
			const scene = new THREE.Scene();

			const aspect = window.innerWidth / window.innerHeight;
			const frustumSize = 20;
			const camera = new THREE.OrthographicCamera(
				(frustumSize * aspect) / -2,
				(frustumSize * aspect) / 2,
				frustumSize / 2,
				frustumSize / -2,
				0.1,
				1000,
			);

			const renderer = new THREE.WebGLRenderer({
				canvas,
				alpha: true,
				antialias: true,
			});
			renderer.setSize(window.innerWidth, window.innerHeight);
			renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

			const planeWidth = frustumSize * aspect;
			const planeHeight = frustumSize;
			const geometry = new THREE.PlaneGeometry(
				planeWidth,
				planeHeight,
				100,
				100,
			);

			const material = new THREE.ShaderMaterial({
				uniforms: {
					uTime: { value: 0 },
					uMouse: { value: new THREE.Vector2(0.5, 0.5) },
					uColorStart: { value: new THREE.Color(0x666666) },
					uColorEnd: { value: new THREE.Color(0x999999) },
				},
				vertexShader: `
					uniform float uTime;
					uniform vec2 uMouse;
					varying vec2 vUv;
					varying float vElevation;

					void main() {
						vUv = uv;
						vec3 pos = position;

						vec2 mousePos = vec2(uMouse.x * 20.0 - 10.0, uMouse.y * 20.0 - 10.0);
						float distToMouse = length(pos.xy - mousePos);
						float mouseInfluence = smoothstep(8.0, 0.0, distToMouse) * 1.5;

						float wave1 = sin(pos.x * 0.5 + uTime * 0.5) * 0.5;
						float wave2 = sin(pos.y * 0.3 + uTime * 0.3) * 0.5;
						float wave3 = sin((pos.x + pos.y) * 0.4 + uTime * 0.4) * 0.3;

						pos.z = wave1 + wave2 + wave3 + mouseInfluence;
						vElevation = pos.z;

						gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
					}
				`,
				fragmentShader: `
					uniform vec3 uColorStart;
					uniform vec3 uColorEnd;
					uniform float uTime;
					varying vec2 vUv;
					varying float vElevation;

					void main() {
						float elevation = vElevation * 2.0;
						float contour = fract(elevation * 3.0);
						float lineWidth = 0.15;
						float line = smoothstep(0.0, lineWidth, contour) * smoothstep(1.0, 1.0 - lineWidth, contour);
						vec3 color = mix(uColorStart, uColorEnd, vElevation * 0.5 + 0.5);
						float alpha = mix(0.05, 0.25, 1.0 - line);
						gl_FragColor = vec4(color, alpha);
					}
				`,
				transparent: true,
				side: THREE.DoubleSide,
			});

			const mesh = new THREE.Mesh(geometry, material);
			scene.add(mesh);
			camera.position.z = 10;
			camera.lookAt(0, 0, 0);

			const clock = new THREE.Clock();
			const mouse = { x: 0.5, y: 0.5 };
			const targetMouse = { x: 0.5, y: 0.5 };

			window.addEventListener("mousemove", (e) => {
				targetMouse.x = e.clientX / window.innerWidth;
				targetMouse.y = 1.0 - e.clientY / window.innerHeight;
			});

			const animate = () => {
				material.uniforms.uTime.value = clock.getElapsedTime();
				mouse.x += (targetMouse.x - mouse.x) * 0.05;
				mouse.y += (targetMouse.y - mouse.y) * 0.05;
				material.uniforms.uMouse.value.set(mouse.x, mouse.y);
				renderer.render(scene, camera);
				requestAnimationFrame(animate);
			};
			animate();

			window.addEventListener("resize", () => {
				const aspect = window.innerWidth / window.innerHeight;
				const frustumSize = 20;
				camera.left = (frustumSize * aspect) / -2;
				camera.right = (frustumSize * aspect) / 2;
				camera.top = frustumSize / 2;
				camera.bottom = frustumSize / -2;
				camera.updateProjectionMatrix();
				renderer.setSize(window.innerWidth, window.innerHeight);
				renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
			});
		});
	};

	// ─── Hero Scroll Zoom ─────────────────────────────────────────────────────
	const initHeroScroll = () => {
		const hero = document.querySelector(".hero");
		const heroInner = document.querySelector(".hero-inner") as HTMLElement;
		const zoomLetter = document.querySelector(".zoom-letter") as HTMLElement;

		if (!hero || !heroInner || !zoomLetter) return;

		const updateOrigin = () => {
			const innerTransform = heroInner.style.transform;
			const innerTransition = heroInner.style.transition;
			const innerAnimation = heroInner.style.animation;

			const titleWords = document.querySelectorAll(".title-word");
			const savedTransforms = Array.from(titleWords).map(
				(el) => (el as HTMLElement).style.transform,
			);
			const savedAnimations = Array.from(titleWords).map(
				(el) => (el as HTMLElement).style.animation,
			);

			heroInner.style.transform = "none";
			heroInner.style.transition = "none";
			heroInner.style.animation = "none";

			titleWords.forEach((el) => {
				(el as HTMLElement).style.transform = "none";
				(el as HTMLElement).style.transition = "none";
				(el as HTMLElement).style.animation = "none";
			});

			const savedZoomTransform = zoomLetter.style.transform;
			zoomLetter.style.transform = "none";
			zoomLetter.offsetHeight; // force reflow

			const heroRect = hero.getBoundingClientRect();
			const zoomRect = zoomLetter.getBoundingClientRect();
			const innerRect = heroInner.getBoundingClientRect();

			heroInner.style.transform = innerTransform;
			heroInner.style.transition = innerTransition;
			heroInner.style.animation = innerAnimation;

			titleWords.forEach((el, idx) => {
				(el as HTMLElement).style.transform = savedTransforms[idx];
				(el as HTMLElement).style.animation = savedAnimations[idx];
			});
			zoomLetter.style.transform = savedZoomTransform;

			const originX = zoomRect.left - innerRect.left + zoomRect.width / 2;
			const originY = zoomRect.top - innerRect.top + zoomRect.height / 2;
			gsap.set(heroInner, { transformOrigin: `${originX}px ${originY}px` });

			const letterHeroX = zoomRect.left - heroRect.left + zoomRect.width / 2;
			const letterHeroY = zoomRect.top - heroRect.top + zoomRect.height / 2;
			const moveX = heroRect.width / 2 - letterHeroX;
			const moveY = heroRect.height / 2 - letterHeroY;

			heroInner.dataset.moveX = moveX.toString();
			heroInner.dataset.moveY = moveY.toString();
		};

		updateOrigin();
		window.addEventListener("resize", updateOrigin);
		window.addEventListener("load", updateOrigin);

		const tl = gsap.timeline({
			scrollTrigger: {
				trigger: ".hero",
				start: "top top",
				end: "+=300%",
				scrub: 1,
				pin: true,
				pinSpacing: true,
				invalidateOnRefresh: true,
			},
		});

		tl.to(
			".normal-letter, .title-word:not(:first-child), .subtitle-container, .topo-bg",
			{ ease: "power1.out", duration: 0.5 },
		).to(
			heroInner,
			{
				scale: 800,
				x: () => parseFloat(heroInner.dataset.moveX || "0"),
				y: () => parseFloat(heroInner.dataset.moveY || "0"),
				ease: "power2.in",
				duration: 2,
			},
			0,
		);
	};

	// ─── Boot ─────────────────────────────────────────────────────────────────
	const init = () => {
		initWaveBackground();
		initHeroScroll();
	};

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", init);
	} else {
		init();
	}
</script>