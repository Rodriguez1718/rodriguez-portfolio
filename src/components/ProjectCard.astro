---
interface Props {
	title: string;
	summary?: string;
	featuredImage?: { src: string; alt?: string } | string | null;
	href: string;
	client?: string;
	year?: number | string;
	categories?: string[];
	tags?: string[];
}

const { title, summary, featuredImage, href, client, year, categories, tags } =
	Astro.props;

// Combine categories and tags for display
const allTags = [...(categories || []), ...(tags || [])];

// Resolve image src/alt
const imgSrc =
	typeof featuredImage === "string"
		? featuredImage
		: featuredImage?.src ?? null;
const imgAlt =
	typeof featuredImage === "object" && featuredImage !== null
		? (featuredImage as { src: string; alt?: string }).alt ?? title
		: title;
---

<article class="project-card">
	<a href={href} class="card-link">
		<div class="card-image">
			{imgSrc ? (
				<img src={imgSrc} alt={imgAlt} loading="lazy" />
			) : (
				<div class="card-image-placeholder" aria-hidden="true" />
			)}
			<div class="card-overlay">
				<span class="card-view">View Project</span>
			</div>
		</div>
		<div class="card-content">
			<h2 class="card-title">{title}</h2>
			<div class="card-meta">
				{client && <span class="card-client">{client}</span>}
				{client && year && <span class="card-separator">·</span>}
				{year && <span class="card-year">{year}</span>}
			</div>
			{summary && <p class="card-summary">{summary}</p>}
			{
				allTags.length > 0 && (
					<div class="card-categories">
						{allTags.map((tag) => (
							<span class="card-category">{tag}</span>
						))}
					</div>
				)
			}
		</div>
	</a>
</article>

<style>
	.project-card {
		position: relative;
		perspective: 1000px;
	}

	.card-link {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-md, 1rem);
		text-decoration: none;
		color: inherit;
		transform-style: preserve-3d;
		will-change: transform;
	}

	.card-image {
		position: relative;
		overflow: hidden;
		border-radius: 0;
		border: 1px solid var(--color-border);
		transform-style: preserve-3d;
		will-change: transform;
	}

	.card-image img {
		width: 100%;
		height: auto;
		aspect-ratio: 4 / 3;
		object-fit: cover;
		transition: filter var(--transition-slow, 300ms ease);
		filter: grayscale(1) contrast(1.1);
		will-change: transform;
	}

	.card-image-placeholder {
		width: 100%;
		aspect-ratio: 4 / 3;
		background: var(--color-surface);
	}

	.card-overlay {
		position: absolute;
		inset: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		background: rgba(0, 0, 0, 0);
		transition: background var(--transition-base, 200ms ease);
	}

	.card-view {
		font-family: var(--font-mono, monospace);
		font-size: var(--font-size-sm, 0.875rem);
		color: white;
		padding: var(--spacing-sm, 0.5rem) var(--spacing-md, 1rem);
		border: 1px solid white;
		border-radius: 0;
		opacity: 0;
		transform: translateY(10px);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		transition:
			opacity var(--transition-base, 200ms ease),
			transform var(--transition-base, 200ms ease);
	}

	.project-card:hover .card-image img {
		filter: grayscale(0) contrast(1);
	}

	.project-card:hover .card-overlay {
		background: rgba(0, 0, 0, 0.5);
	}

	.project-card:hover .card-view {
		opacity: 1;
		transform: translateY(0);
	}

	.card-content {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-xs, 0.25rem);
		padding: var(--spacing-xs) 0;
	}

	.card-title {
		font-family: 'Syne', sans-serif;
		font-size: var(--font-size-lg, 1.25rem);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: -0.02em;
		transition: color var(--transition-fast, 150ms ease);
	}

	.project-card:hover .card-title {
		color: var(--color-accent, #7c3aed);
	}

	.card-meta {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--color-muted, #6b7280);
	}

	.card-separator {
		margin: 0 var(--spacing-xs, 0.25rem);
	}

	.card-summary {
		font-size: var(--font-size-sm, 0.875rem);
		color: var(--color-muted, #6b7280);
		line-height: 1.6;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
		margin-top: var(--spacing-xs);
	}

	.card-categories {
		display: flex;
		flex-wrap: wrap;
		gap: var(--spacing-sm, 0.5rem);
		margin-top: var(--spacing-sm, 0.5rem);
	}

	.card-category {
		font-family: var(--font-mono);
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--color-muted, #6b7280);
		padding: 2px 8px;
		border: 1px dashed var(--color-border, #e5e7eb);
		border-radius: 0;
	}

	.project-card:hover .card-category {
		border-color: var(--color-accent-muted);
		color: var(--color-accent);
	}
</style>

<script>
	import { gsap } from "gsap";

	const initCardTilt = () => {
		const cards = document.querySelectorAll(".project-card");

		cards.forEach((card) => {
			const link = card.querySelector(".card-link") as HTMLElement;
			const image = card.querySelector(".card-image img") as HTMLElement;

			if (!link) return;

			// QuickTo animations for smooth mouse tracking
			const rotateX = gsap.quickTo(link, "rotationX", {
				duration: 0.4,
				ease: "power3.out",
			});
			const rotateY = gsap.quickTo(link, "rotationY", {
				duration: 0.4,
				ease: "power3.out",
			});

			const imageScale = image ? gsap.quickTo(image, "scale", {
				duration: 0.4,
				ease: "power3.out",
			}) : null;
			const innerX = image ? gsap.quickTo(image, "x", {
				duration: 0.4,
				ease: "power3.out",
			}) : null;
			const innerY = image ? gsap.quickTo(image, "y", {
				duration: 0.4,
				ease: "power3.out",
			}) : null;

			card.addEventListener("pointermove", (e: Event) => {
				const mouseEvent = e as PointerEvent;
				const rect = card.getBoundingClientRect();

				// Get normalized mouse coords: -0.5 to 0.5 relative to card center
				const x = (mouseEvent.clientX - rect.left) / rect.width - 0.5;
				const y = (mouseEvent.clientY - rect.top) / rect.height - 0.5;

				// Calculate tilt angle: max 12 degrees
				// rotationX is based on Y movement (up/down)
				// rotationY is based on X movement (left/right)
				rotateX(-y * 12);
				rotateY(x * 12);

				// Parallax effect on the inner image: translation and scale
				if (imageScale) imageScale(1.05);
				if (innerX && innerY) {
					innerX(x * 20);
					innerY(y * 20);
				}
			});

			card.addEventListener("pointerleave", () => {
				// Reset rotation and translation
				rotateX(0);
				rotateY(0);
				if (imageScale) imageScale(1);
				if (innerX && innerY) {
					innerX(0);
					innerY(0);
				}
			});
		});
	};

	// Initialize on page load
	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", initCardTilt);
	} else {
		initCardTilt();
	}
</script>
