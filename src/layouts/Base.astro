---
import { getEntry } from "astro:content";
import "../styles/theme.css";

interface Props {
	title?: string;
	description?: string;
	image?: string;
	type?: "website" | "article";
}

const { title, description, image, type = "website" } = Astro.props;

const settingsEntry = await getEntry("settings", "index");
const siteTitle = settingsEntry?.data?.title || "Kris Rodriguez";
const siteTagline = settingsEntry?.data?.tagline || "Design & Development";
const fullTitle = title ? `${title} — ${siteTitle}` : siteTitle;
const siteDescription = description || siteTagline;

const navLinks = [
	{ label: "Work", url: "/work", num: "01" },
	{ label: "About", url: "/#about", num: "02" },
	{ label: "Contact", url: "/#contact", num: "03" },
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{fullTitle}</title>
		<meta name="description" content={siteDescription} />
		{image && <meta property="og:image" content={image} />}
		<meta property="og:type" content={type} />
		<meta property="og:title" content={fullTitle} />
		<meta property="og:description" content={siteDescription} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Anton&family=Allura&family=Playfair+Display:ital,wght@0,400..700;1,400..700&family=Syne:wght@400..800&family=Space+Mono:wght@700&display=swap"
			rel="stylesheet"
		/>
		<link
			rel="alternate"
			type="application/rss+xml"
			title={`${siteTitle} RSS Feed`}
			href="/rss.xml"
		/>
	</head>
	<body>
		<!-- Page Loader -->
		<div class="page-loader" id="pageLoader">
			<div class="loader-grid" id="gridLines"></div>
			<div class="loader-content">
				<div class="loader-number" id="loaderNumber">0%</div>
			</div>
		</div>

		<!-- Top Bar -->
		<header class="site-header">
			<nav class="nav">
				<a href="/" class="site-title">{siteTitle}</a>
				<button class="menu-btn" id="menuBtn" aria-label="Open menu">
					<span class="menu-btn-label" id="menuLabel">Menu</span>
					<span class="menu-btn-icon" id="menuIcon">
						<span></span>
						<span></span>
					</span>
				</button>
			</nav>
		</header>

		<!-- Fullscreen Menu Overlay -->
		<div class="menu-overlay" id="menuOverlay">
			<div class="menu-overlay-inner">
				<nav class="menu-nav">
					{navLinks.map((item) => (
						<a href={item.url} class="menu-nav-item" data-num={item.num}>
							<span class="menu-nav-num">{item.num}</span>
							<span class="menu-nav-label">{item.label}</span>
						</a>
					))}
				</nav>
				<div class="menu-footer">
					<span class="menu-tagline">{siteTagline}</span>
					<a href="/keystatic" class="menu-admin">Admin</a>
				</div>
			</div>
		</div>

		<main>
			<slot />
		</main>

		<footer class="site-footer">
			<div class="footer-content">
				<div class="footer-hero">
					<h2 class="footer-name">RODRIGUEZ</h2>
				</div>
				<div class="footer-bottom">
					<div class="footer-brand">
						<p class="footer-tagline">{siteTagline}</p>
					</div>
					<div class="footer-right">
						<p class="footer-powered">
							Built with <a href="https://astro.build">Astro</a>
						</p>
					</div>
				</div>
			</div>
		</footer>

		<script is:inline>
			document.addEventListener('DOMContentLoaded', () => {
				// ── Page Loader ──
				const loader = document.getElementById('pageLoader');
				const loaderNumber = document.getElementById('loaderNumber');
				const gridLines = document.getElementById('gridLines');
				const gridCount = 28;
				const lines = [];

				if (gridLines) {
					const W = window.innerWidth;
					const center = W / 2;

					for (let i = 0; i < gridCount; i++) {
						const line = document.createElement('div');
						line.className = 'grid-line';
						const x = (i / (gridCount - 1)) * W;
						line.style.left = x + 'px';
						gridLines.appendChild(line);
						lines.push({ el: line, x });
					}

					let progress = 0;

					const interval = setInterval(() => {
						progress += Math.random() * 5 + 2;
						if (progress > 100) progress = 100;

						if (loaderNumber) {
							loaderNumber.textContent = Math.floor(progress) + '%';
						}

						const scaleY = 0.05 + (progress / 100) * 0.95;
						lines.forEach(({ el }) => {
							el.style.transition = 'none';
							el.style.transform = `scaleY(${scaleY})`;
						});

						if (progress >= 100) {
							clearInterval(interval);

							setTimeout(() => {
								if (loaderNumber) {
									loaderNumber.style.transform = 'translateY(120px)';
									loaderNumber.style.opacity = '0';
								}
							}, 200);

							setTimeout(() => {
								lines.forEach(({ el, x }) => {
									const dist = x - center;
									el.style.transition = 'transform 0.7s cubic-bezier(0.76,0,0.24,1)';
									el.style.transform = `translateX(${-dist}px) scaleY(1)`;
								});
							}, 500);

							setTimeout(() => {
								lines.forEach(({ el }) => {
									el.style.display = 'none';
								});

								loader.style.background = 'transparent';

								const left = document.createElement('div');
								const right = document.createElement('div');
								const shared = `
									position: absolute; top: 0; height: 100%;
									width: 50%; background: var(--color-bg);
									transition: transform 0.7s cubic-bezier(0.76,0,0.24,1);
								`;
								left.style.cssText = shared + 'left: 0;';
								right.style.cssText = shared + 'right: 0;';
								loader.appendChild(left);
								loader.appendChild(right);

								left.getBoundingClientRect();
								left.style.transform = 'translateX(-100%)';
								right.style.transform = 'translateX(100%)';

								setTimeout(() => {
									loader?.classList.add('loaded');
								}, 700);
							}, 1300);
						}
					}, 110);
				}

				// ── Menu Toggle ──
				const menuBtn = document.getElementById('menuBtn');
				const menuOverlay = document.getElementById('menuOverlay');
				const menuLabel = document.getElementById('menuLabel');

				let menuOpen = false;

				menuBtn?.addEventListener('click', () => {
					menuOpen = !menuOpen;
					menuOverlay?.classList.toggle('is-open', menuOpen);
					menuBtn?.classList.toggle('is-open', menuOpen);
					if (menuLabel) menuLabel.textContent = menuOpen ? 'Close' : 'Menu';
					document.body.style.overflow = menuOpen ? 'hidden' : '';
				});

				document.querySelectorAll('.menu-nav-item').forEach(link => {
					link.addEventListener('click', () => {
						menuOpen = false;
						menuOverlay?.classList.remove('is-open');
						menuBtn?.classList.remove('is-open');
						if (menuLabel) menuLabel.textContent = 'Menu';
						document.body.style.overflow = '';
					});
				});
			});
		</script>

		<style is:global>
			@layer base;

			@layer base {
				*,
				*::before,
				*::after {
					box-sizing: border-box;
					margin: 0;
					padding: 0;
				}

				:root {
					--color-bg: #0a0a0a;
					--color-text: #f5f5f5;
					--color-muted: #a1a1aa;
					--color-border: #27272a;
					--color-surface: #18181b;
					--color-accent: #a78bfa;
					--color-accent-muted: #7c3aed;

					--font-sans: system-ui, -apple-system, sans-serif;
					--font-mono: ui-monospace, monospace;

					--font-size-sm: 0.875rem;
					--font-size-base: 1.0625rem;
					--font-size-lg: 1.25rem;
					--font-size-xl: 1.5rem;
					--font-size-2xl: 2rem;
					--font-size-3xl: 2.75rem;
					--font-size-4xl: 3.5rem;

					--spacing-xs: 0.25rem;
					--spacing-sm: 0.5rem;
					--spacing-md: 1rem;
					--spacing-lg: 1.5rem;
					--spacing-xl: 2rem;
					--spacing-2xl: 3rem;
					--spacing-3xl: 4rem;
					--spacing-4xl: 6rem;

					--max-width: 720px;
					--wide-width: 1200px;
					--radius: 4px;

					--transition-fast: 150ms ease;
					--transition-base: 200ms ease;
					--transition-slow: 300ms ease;
				}

				html {
					scroll-behavior: smooth;
					overflow-x: clip;
					max-width: 100vw;
				}

				body {
					font-family: var(--font-sans);
					font-size: var(--font-size-base);
					line-height: 1.6;
					color: var(--color-text);
					background: var(--color-bg);
					-webkit-font-smoothing: antialiased;
					min-height: 100vh;
					overflow-x: clip;
					max-width: 100vw;
					position: relative;
				}

				a { color: currentColor; }

				img {
					max-width: 100%;
					height: auto;
					display: block;
				}

				h1, h2, h3, h4 {
					font-family: var(--font-serif);
					font-weight: 500;
					line-height: 1.2;
				}

				h1 { font-size: var(--font-size-4xl); }
				h2 { font-size: var(--font-size-2xl); }
				h3 { font-size: var(--font-size-xl); }
			}
		</style>

		<style is:global>
			/* ── Loader ── */
			.page-loader {
				position: fixed;
				top: 0;
				left: 0;
				width: 100vw;
				height: 100vh;
				background: var(--color-bg);
				z-index: 9999;
			}

			.page-loader.loaded {
				display: none;
			}

			.loader-grid {
				position: absolute;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
			}

			.grid-line {
				position: absolute;
				top: 0;
				width: 1px;
				height: 100%;
				background: rgba(255, 255, 255, 0.18);
				transform: scaleY(0.05);
				transform-origin: center;
			}

			.loader-content {
				position: fixed;
				bottom: var(--spacing-2xl);
				right: var(--spacing-2xl);
				z-index: 10;
			}

			.loader-number {
				font-family: 'Anton', sans-serif;
				font-size: clamp(3rem, 10vw, 8rem);
				font-weight: 700;
				color: var(--color-text);
				letter-spacing: 0.05em;
				line-height: 1;
				transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.6s ease;
			}

			/* ── Header ── */
			.site-header {
				position: fixed;
				top: 0;
				left: 0;
				right: 0;
				width: 100%;
				padding: var(--spacing-xl) var(--spacing-xl);
				z-index: 1000;
				mix-blend-mode: difference;
			}

			.nav {
				display: flex;
				justify-content: space-between;
				align-items: center;
			}

			.site-title {
				font-family: "Syne", sans-serif;
				font-size: var(--font-size-sm);
				font-weight: 800;
				text-decoration: none;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: var(--color-text);
			}

			/* ── Menu Button ── */
			.menu-btn {
				display: flex;
				align-items: center;
				gap: 10px;
				background: none;
				border: none;
				cursor: pointer;
				color: var(--color-text);
				padding: 0;
			}

			.menu-btn-label {
				font-family: var(--font-mono);
				font-size: 0.7rem;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				color: var(--color-text);
			}

			.menu-btn-icon {
				display: flex;
				flex-direction: column;
				gap: 5px;
				width: 22px;
			}

			.menu-btn-icon span {
				display: block;
				width: 100%;
				height: 1px;
				background: var(--color-text);
				transition: transform 0.4s cubic-bezier(0.76,0,0.24,1), opacity 0.3s ease;
				transform-origin: center;
			}

			.menu-btn.is-open .menu-btn-icon span:first-child {
				transform: translateY(3px) rotate(45deg);
			}

			.menu-btn.is-open .menu-btn-icon span:last-child {
				transform: translateY(-3px) rotate(-45deg);
			}

			/* ── Menu Overlay ── */
			.menu-overlay {
				position: fixed;
				inset: 0;
				background: var(--color-bg);
				z-index: 999;
				display: flex;
				flex-direction: column;
				padding: var(--spacing-4xl) var(--spacing-xl) var(--spacing-2xl);
				clip-path: inset(0 0 100% 0);
				transition: clip-path 0.7s cubic-bezier(0.76,0,0.24,1);
			}

			.menu-overlay.is-open {
				clip-path: inset(0 0 0% 0);
			}

			.menu-overlay-inner {
				display: flex;
				flex-direction: column;
				justify-content: space-between;
				height: 100%;
			}

			.menu-nav {
				display: flex;
				flex-direction: column;
				margin-top: auto;
				padding-top: var(--spacing-2xl);
			}

			.menu-nav-item {
				display: flex;
				align-items: baseline;
				gap: var(--spacing-lg);
				text-decoration: none;
				color: var(--color-text);
				padding: var(--spacing-lg) 0;
				border-top: 1px solid var(--color-border);
				transition: color var(--transition-fast);
			}

			.menu-nav-item:last-child {
				border-bottom: 1px solid var(--color-border);
			}

			.menu-nav-item:hover {
				color: var(--color-muted);
			}

			.menu-nav-num {
				font-family: var(--font-mono);
				font-size: 0.7rem;
				color: var(--color-muted);
				letter-spacing: 0.05em;
				flex-shrink: 0;
			}

			.menu-nav-label {
				font-family: "Syne", sans-serif;
				font-size: clamp(2.5rem, 8vw, 7rem);
				font-weight: 800;
				text-transform: uppercase;
				letter-spacing: -0.04em;
				line-height: 1;
				transition: transform 0.4s cubic-bezier(0.16,1,0.3,1);
			}

			.menu-nav-item:hover .menu-nav-label {
				transform: translateX(1rem);
			}

			.menu-footer {
				display: flex;
				justify-content: space-between;
				align-items: flex-end;
				padding-top: var(--spacing-2xl);
			}

			.menu-tagline {
				font-family: var(--font-mono);
				font-size: 0.7rem;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: var(--color-muted);
			}

			.menu-admin {
				font-family: var(--font-mono);
				font-size: 0.7rem;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: var(--color-muted);
				text-decoration: none;
				opacity: 0.5;
				transition: opacity var(--transition-fast);
			}

			.menu-admin:hover {
				opacity: 1;
			}

			/* ── Main ── */
			main {
				min-height: 100vh;
				overflow-x: clip;
				max-width: 100vw;
				position: relative;
				z-index: 1;
				background: var(--color-bg);
			}

			/* ── Footer ── */
			.site-footer {
				width: 100%;
				max-width: 100%;
				margin: 0;
				padding: 0 0 var(--spacing-4xl) 0;
				border-top: 3px solid var(--color-text);
				position: sticky;
				bottom: 0;
				z-index: 0;
			}

			.footer-content {
				display: flex;
				flex-direction: column;
				gap: var(--spacing-3xl);
				padding-top: var(--spacing-lg);
			}

			.footer-hero {
				width: 100%;
				padding: 0 var(--spacing-lg) var(--spacing-3xl) var(--spacing-lg);
				overflow: hidden;
				display: flex;
				justify-content: center;
				align-items: flex-start;
			}

			.footer-name {
				font-family: "Syne", sans-serif;
				font-size: clamp(2rem, 8.5vw, 12rem);
				font-weight: 800;
				text-transform: uppercase;
				letter-spacing: -0.05em;
				line-height: 0.85;
				color: var(--color-text);
				margin: 0;
				padding: 0;
				white-space: nowrap;
				width: 100%;
				text-align: center;
				transform: scaleY(1.8);
				transform-origin: top center;
			}

			.footer-bottom {
				display: flex;
				justify-content: space-between;
				align-items: flex-start;
				max-width: var(--wide-width);
				margin: 0 auto;
				width: 100%;
				padding: 0 var(--spacing-lg);
			}

			.footer-brand {
				display: flex;
				flex-direction: column;
				gap: var(--spacing-xs);
			}

			.footer-tagline {
				font-family: var(--font-mono);
				text-transform: uppercase;
				letter-spacing: 0.05em;
				font-size: var(--font-size-xs);
				color: var(--color-muted);
			}

			.footer-right {
				display: flex;
				flex-direction: column;
				align-items: flex-end;
				gap: var(--spacing-lg);
			}

			.footer-powered {
				font-family: var(--font-mono);
				font-size: 0.75rem;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				color: var(--color-muted);
			}

			.footer-powered a {
				color: var(--color-text);
				text-decoration: none;
				font-weight: 600;
			}

			.footer-powered a:hover {
				text-decoration: underline;
			}

			@media (max-width: 640px) {
				.site-header {
					padding: var(--spacing-md) var(--spacing-md);
				}

				.menu-nav-label {
					font-size: clamp(2rem, 12vw, 4rem);
				}

				.footer-bottom {
					flex-direction: column;
					gap: var(--spacing-xl);
				}

				.footer-content {
					flex-direction: column;
					gap: var(--spacing-xl);
					align-items: center;
					text-align: center;
				}

				.footer-right {
					align-items: center;
				}

				.site-footer {
					padding: var(--spacing-2xl) var(--spacing-md);
				}

				h1 {
					font-size: var(--font-size-3xl);
				}
			}
		</style>
	</body>
</html>