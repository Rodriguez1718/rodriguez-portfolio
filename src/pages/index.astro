<script>
	import { gsap } from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";
	import { MotionPathPlugin } from "gsap/MotionPathPlugin";

	gsap.registerPlugin(ScrollTrigger, MotionPathPlugin);

	// WebGL Wave Background
	const initWaveBackground = () => {
		const canvas = document.getElementById('wave-canvas') as HTMLCanvasElement;
		if (!canvas) return;

		// Import Three.js dynamically
		import('three').then((THREE) => {
			const scene = new THREE.Scene();
			
			// Use orthographic camera for full coverage
			const aspect = window.innerWidth / window.innerHeight;
			const frustumSize = 20;
			const camera = new THREE.OrthographicCamera(
				frustumSize * aspect / -2,
				frustumSize * aspect / 2,
				frustumSize / 2,
				frustumSize / -2,
				0.1,
				1000
			);
			
			const renderer = new THREE.WebGLRenderer({ 
				canvas, 
				alpha: true,
				antialias: true 
			});
			
			renderer.setSize(window.innerWidth, window.innerHeight);
			renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
			
			// Create plane geometry that matches viewport aspect ratio
			const planeWidth = frustumSize * aspect;
			const planeHeight = frustumSize;
			const geometry = new THREE.PlaneGeometry(planeWidth, planeHeight, 100, 100);
			
			// Custom shader material for topographic effect
			const material = new THREE.ShaderMaterial({
				uniforms: {
					uTime: { value: 0 },
					uMouse: { value: new THREE.Vector2(0.5, 0.5) },
					uColorStart: { value: new THREE.Color(0x666666) },
					uColorEnd: { value: new THREE.Color(0x999999) },
				},
				vertexShader: `
					uniform float uTime;
					uniform vec2 uMouse;
					varying vec2 vUv;
					varying float vElevation;
					
					void main() {
						vUv = uv;
						
						vec3 pos = position;
						
						// Distance from mouse position
						vec2 mousePos = vec2(uMouse.x * 20.0 - 10.0, uMouse.y * 20.0 - 10.0);
						float distToMouse = length(pos.xy - mousePos);
						float mouseInfluence = smoothstep(8.0, 0.0, distToMouse) * 1.5;
						
						// Create wave patterns
						float wave1 = sin(pos.x * 0.5 + uTime * 0.5) * 0.5;
						float wave2 = sin(pos.y * 0.3 + uTime * 0.3) * 0.5;
						float wave3 = sin((pos.x + pos.y) * 0.4 + uTime * 0.4) * 0.3;
						
						pos.z = wave1 + wave2 + wave3 + mouseInfluence;
						vElevation = pos.z;
						
						gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
					}
				`,
				fragmentShader: `
					uniform vec3 uColorStart;
					uniform vec3 uColorEnd;
					uniform float uTime;
					varying vec2 vUv;
					varying float vElevation;
					
					void main() {
						// Create topographic contour lines
						float elevation = vElevation * 2.0;
						float contour = fract(elevation * 3.0); // Number of contour lines
						
						// Make lines sharp
						float lineWidth = 0.15;
						float line = smoothstep(0.0, lineWidth, contour) * smoothstep(1.0, 1.0 - lineWidth, contour);
						
						// Color gradient based on elevation
						vec3 color = mix(uColorStart, uColorEnd, vElevation * 0.5 + 0.5);
						
						// Mix background with contour lines
						float alpha = mix(0.05, 0.25, 1.0 - line);
						
						gl_FragColor = vec4(color, alpha);
					}
				`,
				transparent: true,
				side: THREE.DoubleSide,
			});
			
			const mesh = new THREE.Mesh(geometry, material);
			scene.add(mesh);
			
			// Position camera directly above looking down
			camera.position.z = 10;
			camera.lookAt(0, 0, 0);
			
			// Animation loop
			const clock = new THREE.Clock();
			
			// Mouse tracking
			const mouse = { x: 0.5, y: 0.5 };
			const targetMouse = { x: 0.5, y: 0.5 };
			
			window.addEventListener('mousemove', (e) => {
				targetMouse.x = e.clientX / window.innerWidth;
				targetMouse.y = 1.0 - (e.clientY / window.innerHeight);
			});
			
			const animate = () => {
				const elapsedTime = clock.getElapsedTime();
				material.uniforms.uTime.value = elapsedTime;
				
				// Smooth mouse movement with lerp
				mouse.x += (targetMouse.x - mouse.x) * 0.05;
				mouse.y += (targetMouse.y - mouse.y) * 0.05;
				material.uniforms.uMouse.value.set(mouse.x, mouse.y);
				
				renderer.render(scene, camera);
				requestAnimationFrame(animate);
			};
			
			animate();
			
			// Handle resize
			const handleResize = () => {
				const aspect = window.innerWidth / window.innerHeight;
				const frustumSize = 20;
				
				camera.left = frustumSize * aspect / -2;
				camera.right = frustumSize * aspect / 2;
				camera.top = frustumSize / 2;
				camera.bottom = frustumSize / -2;
				camera.updateProjectionMatrix();
				
				renderer.setSize(window.innerWidth, window.innerHeight);
				renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
			};
			
			window.addEventListener('resize', handleResize);
		});
	};

	// Text scramble effect function
	function initScrambleEffect(scrambleEl: Element) {
		const chars = "!<>-_\\/[]{}—=+*^?#________";
		const originalText = scrambleEl.textContent || "";

		// Create random reveal order
		const indices = Array.from(
			{ length: originalText.length },
			(_, i) => i,
		);
		const shuffled = indices.sort(() => Math.random() - 0.5);
		const revealOrder = new Map(shuffled.map((idx, order) => [idx, order]));

		let frame = 0;
		const maxFrames = originalText.length * 0.5;

		const interval = setInterval(() => {
			if (!scrambleEl) {
				clearInterval(interval);
				return;
			}

			scrambleEl.textContent = originalText
				.split("")
				.map((char, index) => {
					const revealAt = revealOrder.get(index) || 0;
					if (frame > revealAt) {
						return originalText[index];
					}
					return chars[Math.floor(Math.random() * chars.length)];
				})
				.join("");

			if (frame >= maxFrames) {
				scrambleEl.textContent = originalText;
				clearInterval(interval);
			}

			frame += 2;
		}, 12);
	}

	const initHeroScroll = () => {
		const hero = document.querySelector(".hero");
		const heroInner = document.querySelector(".hero-inner") as HTMLElement;
		const zoomLetter = document.querySelector(
			".zoom-letter",
		) as HTMLElement;

		if (!hero || !heroInner || !zoomLetter) return;

		const updateOrigin = () => {
			// Save active transforms, transitions, and keyframe animations
			const innerTransform = heroInner.style.transform;
			const innerTransition = heroInner.style.transition;
			const innerAnimation = heroInner.style.animation;

			const titleWords = document.querySelectorAll(".title-word");
			const savedTransforms = Array.from(titleWords).map(
				(el) => (el as HTMLElement).style.transform,
			);
			const savedAnimations = Array.from(titleWords).map(
				(el) => (el as HTMLElement).style.animation,
			);

			// Strip transforms, transitions, and keyframe animations to get clean static layout geometry
			heroInner.style.transform = "none";
			heroInner.style.transition = "none";
			heroInner.style.animation = "none";

			titleWords.forEach((el) => {
				(el as HTMLElement).style.transform = "none";
				(el as HTMLElement).style.transition = "none";
				(el as HTMLElement).style.animation = "none";
			});

			const savedZoomTransform = zoomLetter.style.transform;
			zoomLetter.style.transform = "none";

			// Force reflow
			zoomLetter.offsetHeight;

			// Get layout bounding rects
			const heroRect = hero.getBoundingClientRect();
			const zoomRect = zoomLetter.getBoundingClientRect();
			const innerRect = heroInner.getBoundingClientRect();

			// Restore original styles
			heroInner.style.transform = innerTransform;
			heroInner.style.transition = innerTransition;
			heroInner.style.animation = innerAnimation;

			titleWords.forEach((el, idx) => {
				(el as HTMLElement).style.transform = savedTransforms[idx];
				(el as HTMLElement).style.animation = savedAnimations[idx];
			});

			zoomLetter.style.transform = savedZoomTransform;

			// Calculate center coordinates of the second letter relative to the heroInner container
			// This will be the pivot point from which the entire heroInner scales!
			const originX = zoomRect.left - innerRect.left + zoomRect.width / 2;
			const originY = zoomRect.top - innerRect.top + zoomRect.height / 2;

			gsap.set(heroInner, {
				transformOrigin: `${originX}px ${originY}px`,
			});

			// Calculate center coordinates of the zoom letter relative to the hero container
			// This completely cancels out scroll and viewport position offsets
			const letterHeroX =
				zoomRect.left - heroRect.left + zoomRect.width / 2;
			const letterHeroY =
				zoomRect.top - heroRect.top + zoomRect.height / 2;

			// The screen center relative to the hero container (which is 100vw x 100vh)
			const targetCenterX = heroRect.width / 2;
			const targetCenterY = heroRect.height / 2;

			// The distance we need to translate heroInner to center the zoom letter
			const moveX = targetCenterX - letterHeroX;
			const moveY = targetCenterY - letterHeroY;

			// Store move coordinates on heroInner so they can be accessed dynamically
			heroInner.dataset.moveX = moveX.toString();
			heroInner.dataset.moveY = moveY.toString();
		};

		// Run layout-clean calculations
		updateOrigin();

		// Recalculate on window resize or load
		window.addEventListener("resize", updateOrigin);
		window.addEventListener("load", updateOrigin);

		// Animate title zoom and background opacity fade
		const tl = gsap.timeline({
			scrollTrigger: {
				trigger: ".hero",
				start: "top top",
				end: "+=300%", // Longer scroll distance slows down zoom
				scrub: 1, // More lag for smoother feel
				pin: true,
				pinSpacing: true,
				invalidateOnRefresh: true,
			},
		});

		tl.to(
			".normal-letter, .title-word:not(:first-child), .subtitle-container, .topo-bg",
			{
				ease: "power1.out",
				duration: 0.5, // Slower fade out
			},
		).to(
			heroInner,
			{
				scale: 800,
				x: () => parseFloat(heroInner.dataset.moveX || "0"),
				y: () => parseFloat(heroInner.dataset.moveY || "0"),
				ease: "power2.in",
				duration: 2, // Slower zoom
			},
			0,
		);
		// Initial state for flying element and section elements (hidden and translated down)
		gsap.set(".flying-element", {
			opacity: 0,
			scale: 0.5,
		});

		gsap.set(
			".about-number, .about-heading, .about-badge, .about-content > *",
			{
				opacity: 0,
				y: 40,
			},
		);

		gsap.set(".skills-number, .skills-heading, .skills-intro, .skill-row", {
			opacity: 0,
			y: 40,
		});

		// Master Horizontal Scroll Timeline
		const horizontalTl = gsap.timeline({
			scrollTrigger: {
				trigger: ".horizontal-scroll-container",
				start: "top top",
				end: "+=500%", // Longer scroll distance for slower animation speed
				pin: true,
				pinSpacing: true,
				scrub: 1, // Smoother scroll lag so movements are less abrupt
				invalidateOnRefresh: true,
			},
		});

		// Glide the rotating brutalist star along the SVG dashed bezier curve with fade in
		horizontalTl
			.to(
				".flying-element",
				{
					opacity: 1,
					scale: 1,
					duration: 0.5,
					ease: "power2.out",
				},
				0,
			)
			.to(
				".flying-element",
				{
					motionPath: {
						path: "#flying-path",
						align: "#flying-path",
						autoRotate: false,
						alignOrigin: [0.5, 0.5],
					},
					rotation: 720,
					duration: 3.0,
					ease: "none",
				},
				0,
			)


		// 1. Fade up the about section contents (starts immediately, completes fully before slide)
		horizontalTl
			.to(
				".about-number, .about-heading, .about-badge, .about-content > *",
				{
					opacity: 1,
					y: 0,
					duration: 0.8,
					stagger: 0.05,
					ease: "power2.out",
					onStart: () => {
						// Trigger scramble when content starts fading in
						const scrambleEl =
							document.querySelector("[data-scramble]");
						if (scrambleEl) {
							initScrambleEffect(scrambleEl);
						}
					},
				},
				0,
			)
			// 2. Slide the skills section horizontally into view (starts after about section has fully faded in and rested)
			.to(
				".horizontal-track",
				{
					x: "-100vw",
					duration: 1.5,
					ease: "power2.inOut",
				},
				1.0, // Delay the start of the slide until t = 1.0 (about finishes and sits visible for a bit)
			)
			// 3. Fade up the skills section contents as they arrive and slide into place
			.to(
				".skills-number, .skills-heading, .skills-intro, .skill-row",
				{
					opacity: 1,
					y: 0,
					duration: 0.8,
					stagger: 0.05,
					ease: "power2.out",
				},
				1.8, // Starts at t = 1.8 (mid-to-end of the slide animation)
			);
	};

	// Start animation when DOM is fully built
	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", () => {
			initWaveBackground();
			initHeroScroll();
		});
	} else {
		initWaveBackground();
		initHeroScroll();
	}

	// Featured Projects Timeline Animation
	const initFeaturedTimeline = () => {
		const timelineItems = gsap.utils.toArray(".timeline-item");
		if (timelineItems.length === 0) return;

		timelineItems.forEach((item: any) => {
			const dot = item.querySelector(".timeline-dot");
			const card = item.querySelector(".timeline-card-wrapper");
			const line = item.querySelector(".timeline-line");

			// Fade in / up the card wrapper
			gsap.fromTo(
				card,
				{ opacity: 0, y: 40 },
				{
					opacity: 1,
					y: 0,
					duration: 0.8,
					ease: "power2.out",
					scrollTrigger: {
						trigger: item,
						start: "top 85%",
						toggleActions: "play none none reverse",
					},
				},
			);

			// Activate/glow the dot
			if (dot) {
				gsap.fromTo(
					dot,
					{
						scale: 0.8,
						backgroundColor: "var(--color-bg)",
						borderColor: "var(--color-text)",
					},
					{
						scale: 1.2,
						backgroundColor: "var(--color-accent)",
						borderColor: "var(--color-accent)",
						scrollTrigger: {
							trigger: item,
							start: "top 70%",
							end: "bottom 30%",
							toggleActions: "play reverse play reverse",
						},
					},
				);
			}

			// Grow/draw the vertical line segment
			if (line) {
				gsap.fromTo(
					line,
					{ scaleY: 0 },
					{
						scaleY: 1,
						transformOrigin: "top center",
						ease: "none",
						scrollTrigger: {
							trigger: item,
							start: "top 70%",
							end: "bottom 70%",
							scrub: true,
						},
					},
				);
			}
		});
	};

	// Experience Section GSAP Transitions - Pinned Cards with Blur
	const initExperienceTimeline = () => {
		const cards = gsap.utils.toArray<HTMLElement>(".experience-card");
		if (cards.length === 0) return;

		cards.forEach((card, index) => {
			// Skip animation for last card
			if (index === cards.length - 1) return;

			// Scale down and move down animation
			gsap.to(card, {
				scale: 0.9,
				y: 150,
				scrollTrigger: {
					trigger: cards[index + 1],
					start: "top 70%",
					end: "top 10vh",
					scrub: true,
				},
			});

			// Blur animation - happens very early
			gsap.to(card, {
				filter: "blur(8px)",
				scrollTrigger: {
					trigger: cards[index + 1],
					start: "top 490vh",
					end: "top 10vh",
					scrub: true,
				},
			});
		});
	};

	// Magnetic Buttons
	const initMagneticButtons = () => {
		const zones = document.querySelectorAll(".magnetic-zone");
		const strength = 0.35;

		zones.forEach((zone: any) => {
			const btn = zone.querySelector(".featured-link-btn");
			if (!btn) return;

			let rect: DOMRect | null = null;

			zone.addEventListener("pointerenter", () => {
				rect = zone.getBoundingClientRect();
			});

			zone.addEventListener("mousemove", (e: MouseEvent) => {
				const currentRect = rect || zone.getBoundingClientRect();
				rect = currentRect;
				const x = gsap.utils.mapRange(
					currentRect.left,
					currentRect.right,
					-currentRect.width / 2,
					currentRect.width / 2,
					e.clientX,
				);
				const y = gsap.utils.mapRange(
					currentRect.top,
					currentRect.bottom,
					-currentRect.height / 2,
					currentRect.height / 2,
					e.clientY,
				);

				gsap.to(btn, {
					x: x * strength,
					y: y * strength,
					duration: 0.4,
					ease: "power2.out",
					overwrite: true,
				});
			});

			zone.addEventListener("mouseleave", () => {
				rect = null;
				gsap.to(btn, {
					x: 0,
					y: 0,
					duration: 0.7,
					ease: "elastic.out(1, 0.4)",
					overwrite: true,
				});
			});
		});
	};

	// Initialize features
	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", () => {
			initFeaturedTimeline();
			initExperienceTimeline();
			initMagneticButtons();
		});
	} else {
		initFeaturedTimeline();
		initExperienceTimeline();
		initMagneticButtons();
	}
</script>
