---
import { sanityClient, urlFor } from "../lib/sanity";
import Base from "../layouts/Base.astro";
import ProjectCard from "../components/ProjectCard.astro";
import Hero from "../components/sections/Hero.astro";
import About from "../components/sections/About.astro";
import Skills from "../components/sections/Skills.astro";
import FeaturedWorks from "../components/sections/FeaturedWorks.astro";
import Experience from "../components/sections/Experience.astro";
import Contact from "../components/sections/Contact.astro";

// Types
interface Skill {
	name: string;
	category?: string;
	level?: string;
}

interface Experience {
	role: string;
	company: string;
	start_date: string;
	end_date: string;
	description?: string;
}

interface Contact {
	platform: string;
	display_label: string;
	url: string;
}

interface Project {
	_id: string;
	title: string;
	slug?: { current: string };
	summary?: string;
	featured_image?: any;
	client?: string;
	year?: number;
	tag?: string;
}

interface About {
	content?: string;
}

// Fetch all data from Sanity
const [allProjects, skills, experiences, contacts, about] = await Promise.all([
	sanityClient.fetch<Project[]>(
		`*[_type == "project"] | order(published_at desc)`,
	),
	sanityClient.fetch<Skill[]>(`*[_type == "skill"] | order(_createdAt asc)`),
	sanityClient.fetch<Experience[]>(
		`*[_type == "experience"] | order(_createdAt desc)`,
	),
	sanityClient.fetch<Contact[]>(
		`*[_type == "contact"] | order(_createdAt asc)`,
	),
	sanityClient.fetch<About>(`*[_type == "about"][0]`),
]);

const featuredProjects = allProjects.slice(0, 4);

---

<Base>
	<Hero />
	
	<div class="horizontal-scroll-container">
		<div class="horizontal-track">
			<!-- Motion Path SVG wrapper (placed inside track to slide along horizontally!) -->
			<div class="motion-path-container">
				<svg
					class="motion-svg"
					viewBox="0 0 3840 1080"
					fill="none"
					xmlns="http://www.w3.org/2000/svg">
					<path
						id="flying-path"
						d="M 100 300 C 1000 100, 900 900, 1920 400 C 2900 -100, 2800 900, 3740 300"
						stroke="rgba(0,0,0,0.07)"
						stroke-width="3"
						stroke-dasharray="8 8"></path>
				</svg>
				<div class="flying-element">
					<svg
						width="40"
						height="40"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2.5">
						<path
							d="M12 2 L12 22 M2 12 L22 12 M5 5 L19 19 M5 19 L19 5"
							stroke="#000000"
							stroke-linecap="square"></path>
					</svg>
				</div>
			</div>

			<About content={about?.content} />

			<Skills skills={skills} />
		</div>
	</div>

	<FeaturedWorks projects={featuredProjects} />

	<Experience experiences={experiences} />

	<Contact contacts={contacts} />
</Base>

<style>

	.horizontal-scroll-container {
		width: 100%;
		max-width: 100vw;
		height: 100vh;
		position: relative;
		overflow: hidden;
		background-color: #ffffff;
	}

	.motion-path-container {
		position: absolute;
		top: 0;
		left: 0;
		width: 200vw;
		height: 100%;
		pointer-events: none;
		z-index: 5;
	}

	.motion-svg {
		width: 100%;
		height: 100%;
		position: absolute;
		top: 0;
		left: 0;
	}

	.flying-element {
		position: absolute;
		top: 0;
		left: 0;
		width: 40px;
		height: 40px;
		transform: translate(-50%, -50%);
		transform-origin: center center;
		will-change: transform;
	}

	.horizontal-track {
		display: flex;
		flex-direction: row;
		width: 200vw;
		height: 100vh;
		will-change: transform;
	}

	.projects-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: var(--spacing-2xl);
	}

	@media (max-width: 768px) {
		.projects-grid {
			grid-template-columns: 1fr;
		}

		.section-header {
			flex-direction: column;
			gap: var(--spacing-sm);
			align-items: flex-start;
		}

		.horizontal-scroll-container {
			overflow-x: hidden;
		}
	}
</style>

<script>
	import { gsap } from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";
	import { MotionPathPlugin } from "gsap/MotionPathPlugin";

	gsap.registerPlugin(ScrollTrigger, MotionPathPlugin);

	// Text scramble effect function
	function initScrambleEffect(scrambleEl: Element) {
		const chars = "!<>-_\\/[]{}—=+*^?#________";
		const originalText = scrambleEl.textContent || "";

		// Create random reveal order
		const indices = Array.from(
			{ length: originalText.length },
			(_, i) => i,
		);
		const shuffled = indices.sort(() => Math.random() - 0.5);
		const revealOrder = new Map(shuffled.map((idx, order) => [idx, order]));

		let frame = 0;
		const maxFrames = originalText.length * 0.5;

		const interval = setInterval(() => {
			if (!scrambleEl) {
				clearInterval(interval);
				return;
			}

			scrambleEl.textContent = originalText
				.split("")
				.map((char, index) => {
					const revealAt = revealOrder.get(index) || 0;
					if (frame > revealAt) {
						return originalText[index];
					}
					return chars[Math.floor(Math.random() * chars.length)];
				})
				.join("");

			if (frame >= maxFrames) {
				scrambleEl.textContent = originalText;
				clearInterval(interval);
			}

			frame += 2;
		}, 12);
	}

	const initHorizontalScroll = () => {
		// Initial state for flying element and section elements (hidden and translated down)
		gsap.set(".flying-element", {
			opacity: 0,
			scale: 0.5,
		});

		gsap.set(
			".about-number, .about-heading, .about-badge, .about-content > *",
			{
				opacity: 0,
				y: 40,
			},
		);

		gsap.set(".skills-number, .skills-heading, .skills-intro, .skill-row", {
			opacity: 0,
			y: 40,
		});

		// Master Horizontal Scroll Timeline
		const horizontalTl = gsap.timeline({
			scrollTrigger: {
				trigger: ".horizontal-scroll-container",
				start: "top top",
				end: "+=500%", // Longer scroll distance for slower animation speed
				pin: true,
				pinSpacing: true,
				scrub: 1, // Smoother scroll lag so movements are less abrupt
				invalidateOnRefresh: true,
			},
		});

		// Glide the rotating brutalist star along the SVG dashed bezier curve with fade in
		horizontalTl
			.to(
				".flying-element",
				{
					opacity: 1,
					scale: 1,
					duration: 0.5,
					ease: "power2.out",
				},
				0,
			)
			.to(
				".flying-element",
				{
					motionPath: {
						path: "#flying-path",
						align: "#flying-path",
						autoRotate: false,
						alignOrigin: [0.5, 0.5],
					},
					rotation: 720,
					duration: 3.0,
					ease: "none",
				},
				0,
			)


		// 1. Fade up the about section contents (starts immediately, completes fully before slide)
		horizontalTl
			.to(
				".about-number, .about-heading, .about-badge, .about-content > *",
				{
					opacity: 1,
					y: 0,
					duration: 0.8,
					stagger: 0.05,
					ease: "power2.out",
					onStart: () => {
						// Trigger scramble when content starts fading in
						const scrambleEl =
							document.querySelector("[data-scramble]");
						if (scrambleEl) {
							initScrambleEffect(scrambleEl);
						}
					},
				},
				0,
			)
			// 2. Slide the skills section horizontally into view (starts after about section has fully faded in and rested)
			.to(
				".horizontal-track",
				{
					x: "-100vw",
					duration: 1.5,
					ease: "power2.inOut",
				},
				1.0, // Delay the start of the slide until t = 1.0 (about finishes and sits visible for a bit)
			)
			// 3. Fade up the skills section contents as they arrive and slide into place
			.to(
				".skills-number, .skills-heading, .skills-intro, .skill-row",
				{
					opacity: 1,
					y: 0,
					duration: 0.8,
					stagger: 0.05,
					ease: "power2.out",
				},
				1.8, // Starts at t = 1.8 (mid-to-end of the slide animation)
			);
	};

	// Start animation when DOM is fully built
	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", () => {
			initHorizontalScroll();
		});
	} else {
		initHorizontalScroll();
	}

	// Featured Projects Timeline Animation
	const initFeaturedTimeline = () => {
		const timelineItems = gsap.utils.toArray(".timeline-item");
		if (timelineItems.length === 0) return;

		timelineItems.forEach((item: any) => {
			const dot = item.querySelector(".timeline-dot");
			const card = item.querySelector(".timeline-card-wrapper");
			const line = item.querySelector(".timeline-line");

			// Fade in / up the card wrapper
			gsap.fromTo(
				card,
				{ opacity: 0, y: 40 },
				{
					opacity: 1,
					y: 0,
					duration: 0.8,
					ease: "power2.out",
					scrollTrigger: {
						trigger: item,
						start: "top 85%",
						toggleActions: "play none none reverse",
					},
				},
			);

			// Activate/glow the dot
			if (dot) {
				gsap.fromTo(
					dot,
					{
						scale: 0.8,
						backgroundColor: "var(--color-bg)",
						borderColor: "var(--color-text)",
					},
					{
						scale: 1.2,
						backgroundColor: "var(--color-accent)",
						borderColor: "var(--color-accent)",
						scrollTrigger: {
							trigger: item,
							start: "top 70%",
							end: "bottom 30%",
							toggleActions: "play reverse play reverse",
						},
					},
				);
			}

			// Grow/draw the vertical line segment
			if (line) {
				gsap.fromTo(
					line,
					{ scaleY: 0 },
					{
						scaleY: 1,
						transformOrigin: "top center",
						ease: "none",
						scrollTrigger: {
							trigger: item,
							start: "top 70%",
							end: "bottom 70%",
							scrub: true,
						},
					},
				);
			}
		});
	};

	// Experience Section GSAP Transitions - Pinned Cards with Blur
	const initExperienceTimeline = () => {
		const cards = gsap.utils.toArray<HTMLElement>(".experience-card");
		if (cards.length === 0) return;

		// Fade in header elements
		gsap.fromTo(
			".experience-number, .experience-heading, .experience-intro",
			{ opacity: 0, y: 30 },
			{
				opacity: 1,
				y: 0,
				stagger: 0.1,
				scrollTrigger: {
					trigger: ".experience-header",
					start: "top 80%",
					end: "top 50%",
					scrub: true,
				},
			}
		);

		cards.forEach((card, index) => {
			// Fade in card content on scroll
			gsap.fromTo(
				card.querySelector(".experience-card-content"),
				{ opacity: 0, y: 30 },
				{
					opacity: 1,
					y: 0,
					scrollTrigger: {
						trigger: card,
						start: "top 80%",
						end: "top 50%",
						scrub: true,
					},
				}
			);

			// Skip animation for last card
			if (index === cards.length - 1) return;

			// Scale down and move down animation
			gsap.to(card, {
				scale: 0.9,
				y: 150,
				scrollTrigger: {
					trigger: cards[index + 1],
					start: "top 70%",
					end: "top 10vh",
					scrub: true,
				},
			});

			// Blur animation - happens very early
			gsap.to(card, {
				filter: "blur(8px)",
				scrollTrigger: {
					trigger: cards[index + 1],
					start: "top 490vh",
					end: "top 10vh",
					scrub: true,
				},
			});
		});
	};

	// Magnetic Buttons
	const initMagneticButtons = () => {
		const zones = document.querySelectorAll(".magnetic-zone");
		const strength = 0.35;

		zones.forEach((zone: any) => {
			const btn = zone.querySelector(".featured-link-btn");
			if (!btn) return;

			let rect: DOMRect | null = null;

			zone.addEventListener("pointerenter", () => {
				rect = zone.getBoundingClientRect();
			});

			zone.addEventListener("mousemove", (e: MouseEvent) => {
				const currentRect = rect || zone.getBoundingClientRect();
				rect = currentRect;
				const x = gsap.utils.mapRange(
					currentRect.left,
					currentRect.right,
					-currentRect.width / 2,
					currentRect.width / 2,
					e.clientX,
				);
				const y = gsap.utils.mapRange(
					currentRect.top,
					currentRect.bottom,
					-currentRect.height / 2,
					currentRect.height / 2,
					e.clientY,
				);

				gsap.to(btn, {
					x: x * strength,
					y: y * strength,
					duration: 0.4,
					ease: "power2.out",
					overwrite: true,
				});
			});

			zone.addEventListener("mouseleave", () => {
				rect = null;
				gsap.to(btn, {
					x: 0,
					y: 0,
					duration: 0.7,
					ease: "elastic.out(1, 0.4)",
					overwrite: true,
				});
			});
		});
	};

	// Contact section fade in
	const initContactAnimation = () => {
		// Fade in left side
		gsap.fromTo(
			".contact-number, .contact-heading, .contact-intro",
			{ opacity: 0, y: 30 },
			{
				opacity: 1,
				y: 0,
				stagger: 0.1,
				scrollTrigger: {
					trigger: ".contact",
					start: "top 80%",
					end: "top 50%",
					scrub: true,
				},
			}
		);

		// Fade in contact rows
		gsap.fromTo(
			".contact-row",
			{ opacity: 0, x: 30 },
			{
				opacity: 1,
				x: 0,
				stagger: 0.1,
				scrollTrigger: {
					trigger: ".contact-links-list",
					start: "top 80%",
					end: "top 50%",
					scrub: true,
				},
			}
		);
	};

	// Initialize features
	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", () => {
			initFeaturedTimeline();
			initExperienceTimeline();
			initMagneticButtons();
			initContactAnimation();
		});
	} else {
		initFeaturedTimeline();
		initExperienceTimeline();
		initMagneticButtons();
		initContactAnimation();
	}
</script>
