---
import { sanityClient, urlFor } from "../lib/sanity";
import Base from "../layouts/Base.astro";
import ProjectCard from "../components/ProjectCard.astro";

// Types
interface Skill {
	name: string;
	category?: string;
	level?: string;
}

interface Experience {
	role: string;
	company: string;
	start_date: string;
	end_date: string;
	description?: string;
}

interface Contact {
	platform: string;
	display_label: string;
	url: string;
}

interface Project {
	_id: string;
	title: string;
	slug?: { current: string };
	summary?: string;
	featured_image?: any;
	client?: string;
	year?: number;
	tag?: string;
}

interface About {
	content?: string;
}

// Fetch all data from Sanity
const [allProjects, skills, experiences, contacts, about] = await Promise.all([
	sanityClient.fetch<Project[]>(
		`*[_type == "project"] | order(published_at desc)`,
	),
	sanityClient.fetch<Skill[]>(`*[_type == "skill"] | order(_createdAt asc)`),
	sanityClient.fetch<Experience[]>(
		`*[_type == "experience"] | order(_createdAt desc)`,
	),
	sanityClient.fetch<Contact[]>(
		`*[_type == "contact"] | order(_createdAt asc)`,
	),
	sanityClient.fetch<About>(`*[_type == "about"][0]`),
]);

const featuredProjects = allProjects.slice(0, 4);

// Site identity
const title = "Kris Rodriguez";
const titleWords = title.split(" ");
---

<Base>
	<section class="hero">
		<!-- WebGL Wave Background -->
		<canvas id="wave-canvas" class="wave-canvas"></canvas>
		
		<div class="hero-content">
			<div class="hero-inner">
				<!-- Top Border with Text -->
				<div class="hero-top-border">
					<span class="border-text-left">4+ YEARS EXPERIENCE</span>
					<span class="border-text-right">WEB DEVELOPER</span>
				</div>
				
				<!-- Large Title -->
				<div class="title-container">
					{
						titleWords.map((word, index) => (
							<div style="overflow: hidden; max-width: 100%;">
								<h1
									class="title-word"
									style={`
									font-family: 'Syne', sans-serif; 
									font-weight: 800; 
									font-size: ${index === 0 ? "clamp(2.5rem, 10vw, 12rem)" : "clamp(1rem, 5.5vw, 10rem)"};
									transform-origin: left;
									animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) ${index * 0.15}s both;
								`}>
									{index === 0
										? word
												.split("")
												.map((letter, letterIdx) => (
													<span
														class={
															letterIdx === 1
																? "zoom-letter"
																: "normal-letter"
														}>
														{letter}
													</span>
												))
										: word}
								</h1>
							</div>
						))
					}
				</div>

				<!-- Subtitle Wrapper -->
				<div
					class="subtitle-container"
					style="animation: fadeIn 1s ease-out 0.6s both;">
					<div class="indigo-line"></div>
					<p class="hero-tagline">Design &amp; Development</p>
				</div>
			</div>
		</div>
	</section>

	<div class="horizontal-scroll-container">
		<div class="horizontal-track">
			<!-- Motion Path SVG wrapper (placed inside track to slide along horizontally!) -->
			<div class="motion-path-container">
				<svg
					class="motion-svg"
					viewBox="0 0 3840 1080"
					fill="none"
					xmlns="http://www.w3.org/2000/svg">
					<path
						id="flying-path"
						d="M 100 300 C 1000 100, 900 900, 1920 400 C 2900 -100, 2800 900, 3740 300"
						stroke="rgba(0,0,0,0.07)"
						stroke-width="3"
						stroke-dasharray="8 8"></path>
				</svg>
				<div class="flying-element">
					<svg
						width="40"
						height="40"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2.5">
						<path
							d="M12 2 L12 22 M2 12 L22 12 M5 5 L19 19 M5 19 L19 5"
							stroke="#000000"
							stroke-linecap="square"></path>
					</svg>
				</div>
			</div>

			<section class="about" id="about">
				<div class="about-container">
					<div class="about-grid">
						<div class="about-left">
							<div class="about-sticky">
								<span class="about-number">
									[01] // HISTORY
								</span>
								<div class="contact-heading-wrapper">
									<div class="heading-plus top-left">+</div>
									<div class="heading-plus top-right">+</div>
									<h2 class="about-heading">About Me</h2>
								</div>
								
								<div class="about-badge">
									<span class="pulse-dot"></span>
									<span>Available for Work</span>
								</div>
							</div>
						</div>
						<div class="about-right">
							<div class="about-content">
								{
									about?.content ? (
										<p>{about.content}</p>
									) : (
										<p>
											Add your bio in the Sanity Studio
										</p>
									)
								}
							</div>
						</div>
					</div>
				</div>
			</section>

			{
				skills.length > 0 && (
					<section class="skills" id="skills">
						<div class="skills-container">
							<div class="skills-grid-layout">
								<div class="skills-left">
									<div class="skills-sticky">
										<span class="skills-number">
											[02] // EXPERTISE
										</span>
										<div class="contact-heading-wrapper">
											<div class="heading-plus top-left">+</div>
											<div class="heading-plus top-right">+</div>
											<h2 class="skills-heading">Skills</h2>
										</div>
										
										<p class="skills-intro">
											A focused catalog of technologies
											and tools used to construct
											high-performance, aesthetically
											exceptional web platforms.
										</p>
									</div>
								</div>
								<div class="skills-right">
									<div class="skills-list">
										{skills.map((skill: Skill) => (
											<div class="skill-row">
												<div class="skill-meta">
													<span class="skill-name">
														{skill.name}
													</span>
													{skill.category && (
														<span class="skill-category-badge">
															{skill.category}
														</span>
													)}
												</div>
												{skill.level && (
													<div class="skill-level-indicator">
														<span class="skill-level-label">
															{skill.level}
														</span>
													</div>
												)}
											</div>
										))}
									</div>
								</div>
							</div>
						</div>
					</section>
				)
			}
		</div>
	</div>

	{
		featuredProjects.length > 0 ? (
			<section class="featured" id="work">
				<div class="featured-content">
					<div class="featured-left">
						<div class="featured-header">
							<span class="featured-number">
								[03] // PORTFOLIO
							</span>
							<div class="contact-heading-wrapper">
								<div class="heading-plus top-left">+</div>
								<div class="heading-plus top-right">+</div>
								<h2 class="featured-heading">Selected Work</h2>
							</div>
							
							<p class="featured-intro">
								A curated presentation of projects designed and
								engineered to push the boundaries of digital
								interface design.
							</p>
						</div>
						<div class="magnetic-zone">
							<a href="/work" class="featured-link-btn">
								<span>View All Projects</span>
								<span class="arrow">&rarr;</span>
							</a>
						</div>
					</div>
					<div class="featured-right">
						<div class="featured-timeline">
							{featuredProjects.map(
								(project: Project, index: number) => (
									<div class="timeline-item">
										<div class="timeline-marker">
											<div class="timeline-dot" />
											{index <
												featuredProjects.length - 1 && (
												<div class="timeline-line" />
											)}
										</div>
										<div class="timeline-card-wrapper">
											<div class="timeline-project-meta">
												<span class="timeline-project-number">
													0{index + 1}
												</span>
												{project.year && (
													<span class="timeline-project-year">
														{project.year}
													</span>
												)}
											</div>
											<ProjectCard
												title={
													project.title ?? "Untitled"
												}
												summary={project.summary}
												featuredImage={
													project.featured_image
														? urlFor(
																project.featured_image,
															)
																.width(800)
																.url()
														: ""
												}
												href={`/work/${project.slug?.current || project._id}`}
												client={project.client}
												year={project.year}
												tags={
													project.tag
														? project.tag
																.split(",")
																.map(
																	(
																		t: string,
																	) =>
																		t.trim(),
																)
														: []
												}
											/>
										</div>
									</div>
								),
							)}
						</div>
					</div>
				</div>
			</section>
		) : (
			<section class="empty-state">
				<h2>No projects yet</h2>
				<p>Add your first project in the admin panel.</p>
				<a href="/keystatic" class="btn">
					Add a project
				</a>
			</section>
		)
	}

	{
		experiences.length > 0 && (
			<section class="experience" id="experience">
				<!-- Vertical Lines Background -->
				<div class="experience-bg-lines">
					<div class="vertical-line"></div>
					<div class="vertical-line"></div>
					<div class="vertical-line"></div>
					<div class="vertical-line"></div>
					<div class="vertical-line"></div>
					<div class="vertical-line"></div>
				</div>
				
				<div class="experience-container">
					<div class="experience-header">
						<span class="experience-number">
							[04] // TIMELINE
						</span>
						<div class="contact-heading-wrapper">
								<div class="heading-plus top-left">+</div>
								<div class="heading-plus top-right">+</div>
								<h2 class="experience-heading">Experience</h2>
						</div>
						
						<p class="experience-intro">
							A timeline of technical roles, professional
							achievements, and industry contributions.
						</p>
					</div>
					
					<div class="experience-timeline" id="experience-timeline">
						{experiences.map((exp: Experience, index: number) => (
							<div class="experience-card" data-index={index}>
								<div class="experience-card-inner">
									<div class="experience-card-content">
										<div class="experience-card-left">
											<h3 class="experience-card-title">
												{exp.role}
											</h3>
											<div class="experience-card-meta">
												<span class="experience-card-company">
													{exp.company}
												</span>
												<span class="experience-card-dates">
													{exp.start_date} — {exp.end_date}
												</span>
											</div>
											{exp.description && (
												<p class="experience-card-description">
													{exp.description}
												</p>
											)}
										</div>
										<div class="experience-card-right">
											<span class="experience-card-number">
												{String(index + 1).padStart(2, '0')}
											</span>
										</div>
									</div>
								</div>
							</div>
						))}
					</div>
				</div>
			</section>
		)
	}

	{
		contacts.length > 0 && (
			<section class="contact" id="contact">
				
				<div class="contact-grid-layout">
					<div class="contact-left">
						<div class="contact-sticky">
							<span class="contact-number">[05] // CONNECT</span>
							<div class="contact-heading-wrapper">
								<div class="heading-plus top-left">+</div>
								<div class="heading-plus top-right">+</div>
								<h2 class="contact-heading">Contact</h2>
							</div>
							<p class="contact-intro">
								Let's collaborate on your next venture. Reach
								out directly or connect through my digital
								channels.
							</p>
						</div>
					</div>
					<div class="contact-right">
						<div class="contact-links-list">
							{contacts.map((link: Contact) => (
								<a
									href={link.url}
									class="contact-row"
									target="_blank">
									<span class="contact-platform">
										{link.platform}
									</span>
									<div class="contact-details">
										<span class="contact-label">
											{link.display_label}
										</span>
										<span class="contact-arrow">
											&rarr;
										</span>
									</div>
								</a>
							))}
						</div>
					</div>
				</div>
			</section>
		)
	}
</Base>

<style>
	.hero {
		position: relative;
		height: 100vh;
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		overflow: hidden;
		background-color: transparent;
		color: var(--color-text);
		width: 100%;
		max-width: 100vw;
	}

	.hero-top-border {
		position: relative;
		width: 100%;
		height: 1px;
		background: var(--color-text);
		display: flex;
		justify-content: space-between;
		align-items: center;

	}

	.border-text-left,
	.border-text-right {
		font-family: var(--font-mono);
		font-size: 0.65rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--color-text);
		background: var(--color-bg);
		padding: 0 var(--spacing-sm);
		position: relative;
		top: -0.5em;
	}

	.zoom-letter {
		color: #ffffff !important;
		background: none !important;
		-webkit-background-clip: unset !important;
		background-clip: unset !important;
		display: inline-block;
		position: relative;
		font-family: 'Playfair Display', 'Georgia', serif !important;
		font-style: italic;
		font-weight: 700;
	}

	.normal-letter {
		color: var(--color-text) !important;
		background: none !important;
		-webkit-background-clip: unset !important;
		background-clip: unset !important;
		display: inline-block;
		position: relative;
	}

	.wave-canvas {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: 0;
		pointer-events: none;
	}

	.hero-content {
		position: relative;
		z-index: 10;
		width: 100%;
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-4xl) var(--spacing-lg);
		display: flex;
		flex-direction: column;
		justify-content: center;
		box-sizing: border-box;
	}

	.hero-inner {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: var(--spacing-xl);
	}

	.title-container {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-sm);
		width: 100%;
		max-width: 100%;
		cursor: default;
		overflow: hidden;
	}

	.title-word {
		font-family: var(--font-sans-syne), sans-serif;
		font-weight: 800;
		line-height: 0.85;
		text-transform: uppercase;
		letter-spacing: -0.05em;
		white-space: nowrap;
		color: transparent;
		background: linear-gradient(
			135deg,
			var(--color-text) 30%,
			var(--color-muted) 100%
		);
		-webkit-background-clip: text;
		background-clip: text;
	}

	.subtitle-container {
		display: flex;
		align-items: center;
		gap: var(--spacing-md);
		margin-top: var(--spacing-lg);
	}

	.indigo-line {
		width: 48px;
		height: 2px;
		background-color: #6366f1;
	}

	.hero-intro {
		font-size: var(--font-size-md);
		color: var(--color-muted);
		max-width: 600px;
		margin: var(--spacing-md) auto 0;
	}

	.hero-tagline {
		font-size: clamp(1.75rem, 3vw, 2.25rem);
		color: #d1d5db;
		font-family: "Playfair Display", "Georgia", serif;
		font-style: italic;
		font-weight: 400;
		letter-spacing: 0.03em;
		line-height: 1.4;
	}

	@keyframes fadeUp {
		0% {
			opacity: 0;
			transform: translateY(100%) scaleX(1);
		}
		100% {
			opacity: 1;
			transform: translateY(0) scaleX(1.05);
		}
	}

	@keyframes fadeIn {
		0% {
			opacity: 0;
		}
		100% {
			opacity: 1;
		}
	}

	.horizontal-scroll-container {
		width: 100%;
		max-width: 100vw;
		height: 100vh;
		position: relative;
		overflow: hidden;
		background-color: #ffffff;
	}

	.motion-path-container {
		position: absolute;
		top: 0;
		left: 0;
		width: 200vw;
		height: 100%;
		pointer-events: none;
		z-index: 5;
	}

	.motion-svg {
		width: 100%;
		height: 100%;
		position: absolute;
		top: 0;
		left: 0;
	}

	.flying-element {
		position: absolute;
		top: 0;
		left: 0;
		width: 40px;
		height: 40px;
		transform: translate(-50%, -50%);
		transform-origin: center center;
		will-change: transform;
	}

	.horizontal-track {
		display: flex;
		flex-direction: row;
		width: 200vw;
		height: 100vh;
		will-change: transform;
	}

	.about {
		width: 100vw;
		height: 100vh;
		min-height: 100vh;
		flex-shrink: 0;
		display: flex;
		align-items: center;
		background-color: transparent;
		color: #000000;
		position: relative;
		overflow: hidden;
	}

	.about-container {
		width: 100%;
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-4xl) var(--spacing-lg);
		position: relative;
		z-index: 2;
	}

	.about-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--spacing-2xl);
	}

	@media (min-width: 768px) {
		.about-grid {
			grid-template-columns: 2fr 3fr;
			gap: var(--spacing-4xl);
		}
	}

	.about-left {
		display: flex;
		flex-direction: column;
	}

	.about-sticky {
		position: sticky;
		top: var(--spacing-2xl);
	}

	.about-number {
		font-family: var(--font-mono);
		font-size: var(--font-size-sm);
		color: var(--color-accent);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		display: block;
		margin-bottom: var(--spacing-sm);
	}

	.about-heading {
		font-family: "Syne", sans-serif;
		font-size: clamp(2.5rem, 5vw, 4rem);
		font-weight: 800;
		line-height: 1.1;
		text-transform: uppercase;
		color: #000000;
		margin-bottom: var(--spacing-lg);
		letter-spacing: -0.03em;
	}

	.about-badge {
		display: inline-flex;
		align-items: center;
		gap: var(--spacing-sm);
		padding: var(--spacing-xs) var(--spacing-md);
		border: 1px solid var(--color-border);
		background-color: var(--color-surface);
		border-radius: 50px;
		font-family: var(--font-mono);
		font-size: 0.75rem;
		text-transform: uppercase;
		color: var(--color-text);
		width: fit-content;
	}

	.pulse-dot {
		width: 8px;
		height: 8px;
		background-color: #10b981;
		border-radius: 50%;
		animation: pulse 2s infinite;
	}

	@keyframes pulse {
		0% {
			transform: scale(0.95);
			box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7);
		}
		70% {
			transform: scale(1);
			box-shadow: 0 0 0 6px rgba(16, 185, 129, 0);
		}
		100% {
			transform: scale(0.95);
			box-shadow: 0 0 0 0 rgba(16, 185, 129, 0);
		}
	}

	.about-content {
		font-size: var(--font-size-base);
		color: #000000;
		line-height: 1.8;
	}

	.about-content :global(p) {
		margin-bottom: var(--spacing-lg);
		color: #000000;
	}

	.about-content :global(p:first-of-type) {
		font-size: var(--font-size-lg);
		line-height: 1.6;
		color: #000000;
		font-weight: 500;
	}

	.about-content :global(h2) {
		font-family: "Syne", sans-serif;
		font-size: var(--font-size-xl);
		font-weight: 700;
		text-transform: uppercase;
		margin-top: var(--spacing-xl);
		margin-bottom: var(--spacing-sm);
		color: #000000;
	}

	.featured {
		width: 100%;
		min-height: 100vh;
		padding: var(--spacing-4xl) 0;
		border-top: 1px solid var(--color-border);
	}

	.featured-content {
		width: 100%;
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: 0 var(--spacing-lg);
		display: flex;
		gap: var(--spacing-4xl);
		align-items: flex-start;
	}

	.featured-left {
		flex: 0 0 35%;
		position: sticky;
		top: 140px; /* Aligns beautifully below the fixed site header */
		align-self: start;
		display: flex;
		flex-direction: column;
		gap: var(--spacing-2xl);
	}

	.featured-header {
		margin-bottom: var(--spacing-lg);
	}

	.featured-number {
		font-family: var(--font-mono);
		font-size: var(--font-size-sm);
		color: var(--color-accent);
		text-transform: uppercase;
		letter-spacing: 0.1em;
		display: block;
